HIRA_API_KEY=your_hira_service_key
KAKAO_REST_KEY=your_kakao_rest_key
GOOGLE_CLIENT_ID=your_google_client_id
BLUEDOT_JWT_SECRET=long_random_string_for_jwt

# 건축물대장(건축HUB) — 공공데이터포털 인증키 (미설정 시 코드 내 레거시 키 사용)
DATA_GO_KR_SERVICE_KEY=

# PostGIS+pgRouting (선택). 비우고 Fly에 배포하면 도보 폴리곤은 반경 근사만 사용
# POSTGIS_HOST=
# POSTGIS_PORT=5432
# POSTGIS_DB=gis_db
# POSTGIS_USER=postgres
# POSTGIS_PASSWORD=

# Fly.io: fly secrets set KEY=value
# PORTONE_API_KEY=...
# PORTONE_API_SECRET=...
