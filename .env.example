HIRA_API_KEY=your_hira_service_key
KAKAO_REST_KEY=your_kakao_rest_key
GOOGLE_CLIENT_ID=your_google_client_id
BLUEDOT_JWT_SECRET=long_random_string_for_jwt

# 건축물대장(건축HUB) — 공공데이터포털 인증키 (미설정 시 코드 내 레거시 키 사용)
DATA_GO_KR_SERVICE_KEY=

# 도로명주소 검색(JUSO) — 카카오 실패 시 지번·행정구역코드 보조 (미설정 시 개발용 키)
# JUSO_CONFM_KEY=

# PostGIS+pgRouting (선택). 비우고 Fly에 배포하면 도보 폴리곤은 반경 근사만 사용
# POSTGIS_HOST=
# POSTGIS_PORT=5432
# POSTGIS_DB=gis_db
# POSTGIS_USER=postgres
# POSTGIS_PASSWORD=

# 미시 입지(/api/micro-site): 카카오 로컬 키워드 검색에도 KAKAO_REST_KEY 사용(서버 전용, 일일 한도·캐시 30분)

# Fly.io: fly secrets set KEY=value
# PORTONE_API_KEY=...
# PORTONE_API_SECRET=...

# 건축 연차/건축HUB 파이프라인(Fly): 로컬 PC에만 파일·키가 있으면 배포 서버는 비어 있음.
# - data/법정동코드 전체자료.txt 는 git 커밋 후 fly deploy 해야 이미지에 포함됨.
# - fly secrets: HIRA_API_KEY, DATA_GO_KR_SERVICE_KEY(또는 BUILDING_HUB_SERVICE_KEY), KAKAO_REST_KEY(주소→법정동 1순위 권장), JUSO_*(선택)
# 배포 서버 점검: GET /api/health 의 building_pipeline (bjdong_txt_exists, *_key_from_env)
